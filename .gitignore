# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
.env/

# ── Secrets — NEVER commit these ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Test & coverage artifacts ──────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
tests/__pycache__/
tests/**/__pycache__/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# ── ML model files ─────────────────────────────────────────────────────────────
*.gguf
*.bin
*.pt
*.pth
*.pkl
*.safetensors
/models/

# ── DSPy compiled outputs (checked in intentionally, so excluded here)
# app/agents/dspy_optimized_quiz.json  ← keep this one, it's small + useful
# If you ever save larger DSPy artifacts, add them below:
# dspy_cache/

# ── Database & SQLite ──────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
test.db

# ── Data folder (raw PDFs/docs used for ingestion, not source code) ───────────
data/

# ── Alembic local state ────────────────────────────────────────────────────────
# versions/ is committed; only exclude the compiled cache
alembic/__pycache__/
alembic/versions/__pycache__/

# ── Docker ─────────────────────────────────────────────────────────────────────
.dockerignore

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS ─────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── VSCode ─────────────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json

# ── Prometheus local data ──────────────────────────────────────────────────────
prometheus_data/
grafana_data/